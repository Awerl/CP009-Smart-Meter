        <mxCell id="m-mqtt" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" value="MQTT 通信&#xa;（心跳 30s + 掉线重连）" vertex="1">
          <mxGeometry height="55" width="220" x="315" y="110" as="geometry" />
        </mxCell>
        <mxCell id="m-ctrl" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" value="远程控制&#xa;（查看 / 阈值 / 开关）" vertex="1">
