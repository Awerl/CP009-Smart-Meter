        <mxCell id="m-adc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" value="ADC 采样 &amp;amp; 功率计算&#xa;（滑窗均值 N=16）" vertex="1">
