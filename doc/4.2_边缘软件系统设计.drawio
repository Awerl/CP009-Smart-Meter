        <mxCell id="title-42a" parent="1" style="text;html=1;align=center;fontSize=15;fontStyle=1;" value="图 4-3 边缘软件系统架构（应用功能 - FreeRTOS 任务 - 硬件外设 三层）" vertex="1">
          <mxGeometry height="30" width="750" x="50" y="20" as="geometry" />
        </mxCell>
        <mxCell id="app-group" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;fontSize=13;" value="应用功能模块层" vertex="1">
