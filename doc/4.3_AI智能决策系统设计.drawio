          <mxGeometry x="550" y="470" width="230" height="35" as="geometry" />
        </mxCell>
        <mxCell id="sk-schema" value="MCP Skill Schema：&#xa;{ 能力描述 ｜ 参数 schema ｜ 返回 schema }&#xa;模型基于自然语言描述自主选择调用" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#eef6fb;strokeColor=#10739e;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="515" width="230" height="55" as="geometry" />
        </mxCell>
        <mxCell id="llm-api" value="外部 LLM API&#xa;（云端大模型）" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="535" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="guard-bar" value="🛡 安全护栏（Skill 执行前必经）：身份验证 ｜ 命令合法性 ｜ 参数范围 ｜ 高功率二次确认 ｜ 敏感时段（深夜）显式批准 ｜ 历史无操作首次启用大功率追问" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="615" width="710" height="60" as="geometry" />
        </mxCell>
        <mxCell id="downgrade" value="降级路径：云端不可达时，核心能力（手动开关 / 定时 / 过载漏电硬保护 / 本地显示）完全在边缘节点本地实现，不依赖云端；&#xa;仅失去自然语言入口与智能编排。考虑到云端不可达时用户多半也无网络（即时通讯本身已不可达），不再引入额外本地降级模型——把工程复杂度集中在最有价值的能力上。" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fillColor=#fff4e6;strokeColor=#d79b00;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="690" width="710" height="80" as="geometry" />
        </mxCell>
        <mxCell id="edge-group" value="边缘软件层（STM32 节点，详见 图 4-3）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="50" y="820" width="750" height="100" as="geometry" />
        </mxCell>
        <mxCell id="edge-summary" value="STM32 边缘节点：实时采样 ｜ MQTT 状态/指纹上报 ｜ 接收 Skill 下发命令 ｜ 硬保护 ISR 链路独立&#xa;⚠ 任何&quot;实时安全&quot;决策不依赖云端；云端只做非关键路径的智能化增强" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e6;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="855" width="690" height="55" as="geometry" />
        </mxCell>
