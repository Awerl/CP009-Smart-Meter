        <mxCell id="sk-3" value="📊 状态查询 Skill" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="350" width="230" height="35" as="geometry" />
