        <mxCell id="e-sk-guard" value="必经" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2;fontSize=11;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.7;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="sk-schema" target="guard-bar">
