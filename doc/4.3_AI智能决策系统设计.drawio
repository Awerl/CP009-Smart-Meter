          <mxGeometry x="290" y="230" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ag-1" value="①意图理解&#xa;自然语言 → 结构化 Skill 调用&#xa;非关键词匹配，模型语义推断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="270" width="240" height="60" as="geometry" />
