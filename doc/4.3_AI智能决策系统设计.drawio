        <mxCell id="ag-3" value="③冲突检测&#xa;执行前查状态 → 发现冲突反问用户&#xa;&quot;先理解、再校验、最后执行&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cce5ff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="400" width="240" height="60" as="geometry" />
