  <diagram name="软件流程图" id="sw-flow">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title-sw" value="基于 STM32 的智能安全插座 —— 软件流程图 (FreeRTOS 多任务架构)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="1100" height="40" as="geometry" />
        </mxCell>
        <mxCell id="start" value="系统上电启动" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="650" y="80" width="180" height="55" as="geometry" />
        </mxCell>
        <mxCell id="init" value="系统初始化&#10;• GPIO / ADC / TIM / EXTI / UART&#10;• OLED · DS1302 · DHT11 · JQ8900&#10;• ESP8266 AT 配置 · 接入 Wi-Fi&#10;• 连接 MQTT Broker · 订阅主题" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=12" vertex="1" parent="1">
          <mxGeometry x="600" y="170" width="280" height="110" as="geometry" />
        </mxCell>
        <mxCell id="create-tasks" value="创建 4 个任务 + 启动 RTOS 调度器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="310" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="scheduler" value="FreeRTOS 调度器&#10;(按优先级抢占调度)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="600" y="395" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="t1-header" value="① 数据采集任务&#10;优先级：中" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="t1-1" value="定时器周期触发 (100 ms)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="595" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t1-2" value="ADC 多通道采样 (电压 / 电流)&#10;16 窗口滑动平均滤波" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="650" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t1-3" value="计算电压 / 电流 / 有功功率 / 累计电量&#10;(校准系数换算)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="715" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t1-4" value="读 DHT11 温湿度&#10;读 DS1302 当前时间" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="780" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t1-5" value="写入共享数据区 (互斥锁保护)&#10;vTaskDelay → 让出 CPU" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="845" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t2-header" value="② 显示与通信任务&#10;优先级：低" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="370" y="520" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="t2-1" value="读取共享数据区" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="370" y="595" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t2-2" value="OLED 刷新本地界面&#10;(温/湿/电压/电流/功率/时间)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="370" y="650" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t2-3" value="MQTT 数据封包 → ESP8266 → 上传&#10;(JSON：温/湿/U/I/P/状态)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="370" y="715" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t2-4" value="检查 30 s 心跳计时器" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="370" y="780" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t2-5" value="网络掉线？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="395" y="835" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t2-6" value="是 → 触发掉线重连流程&#10;否 → vTaskDelay" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="370" y="910" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t3-header" value="③ 控制任务&#10;优先级：中高" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="680" y="520" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="t3-1" value="阻塞等待命令队列&#10;(MQTT 指令 / 定时事件 / 按键)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="680" y="595" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t3-2" value="命令解析 + 基础校验&#10;(开/关/定时/阈值设置)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="680" y="660" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t3-3" value="校验通过？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="705" y="725" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t3-4" value="GPIO 驱动继电器吸合 / 释放" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="680" y="800" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t3-5" value="状态回报：上传新状态&#10;+ 触发 JQ8900 语音播报" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="680" y="855" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t3-6" value="返回等待下一命令" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="680" y="920" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="t4-header" value="④ 安全保护任务 / 中断&#10;最高优先级 (中断驱动)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd6d6;strokeColor=#b85450;fontSize=13;fontStyle=1;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="990" y="520" width="280" height="55" as="geometry" />
        </mxCell>
        <mxCell id="t4-trigger" value="EXTI 中断触发&#10;过载 (I &gt; 15A) / 漏电 (Ileak &gt; 10mA)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#b85450;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="990" y="595" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t4-1" value="进入 ISR：屏蔽同级中断&#10;通过信号量唤醒保护任务" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="990" y="660" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t4-2" value="连续 3 次采样确认&#10;(过滤瞬时干扰 / 误触发)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="990" y="725" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t4-3" value="确认异常？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1025" y="790" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="t4-4" value="是 → 立即断开继电器&#10;(直接操作 GPIO，不走命令队列)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6e6;strokeColor=#b85450;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="990" y="865" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t4-5" value="设置异常标志 + 投递上报队列&#10;通信任务异步上传告警 + 语音报警" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="990" y="930" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t4-6" value="否 → 视为干扰，恢复中断，返回" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="990" y="995" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="shared" value="📦 共享资源&#10;• 共享数据区 (互斥锁保护)&#10;• 命令队列 / 上报队列&#10;• 二值信号量 (中断 → 任务)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="60" y="1085" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="prio" value="⚙ 优先级编排&#10;保护任务  ＞  控制任务  ＞  采集任务  ＞  显示通信任务&#10;原则：异常断电不被刷新/上报阻塞 (设计目标 ≤ 10 ms，实测 4.2 ms)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff5f5;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="420" y="1085" width="540" height="100" as="geometry" />
        </mxCell>
